# Copy this file to .env.local for safe localhost development.
# .env.local is ignored by git because of *.local in .gitignore.

# Use a separate DEV Supabase project so localhost changes never touch production.
VITE_SUPABASE_URL="https://your-dev-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-dev-anon-key"

# Keep this false (or unset) for safety.
VITE_ALLOW_PROD_DATA_IN_DEV="false"

# Extra safety: when localhost points at production Supabase, block write requests.
# Set to "false" only if you intentionally need local writes.
VITE_BLOCK_WRITES_IN_DEV="true"

# Optional local site URL override
VITE_SITE_URL="http://localhost:8080"
